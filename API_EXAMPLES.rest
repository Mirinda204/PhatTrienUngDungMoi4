// ==================== GET ALL USERS ====================

GET http://localhost:5000/api/users

// Response includes all users with populated role data

// ==================== GET USER BY ID ====================

GET http://localhost:5000/api/users/507f1f77bcf86cd799439012

// ==================== UPDATE USER ====================

PUT http://localhost:5000/api/users/507f1f77bcf86cd799439012
Content-Type: application/json

{
  "fullName": "John Doe Updated",
  "loginCount": 5,
  "avatarUrl": "https://example.com/new-avatar.jpg"
}

// ==================== ENABLE USER (Set status = true) ====================

POST http://localhost:5000/api/users/enable
Content-Type: application/json

{
  "email": "john@example.com",
  "username": "john_doe"
}

// Response:
// {
//   "message": "User enabled successfully",
//   "data": {
//     "_id": "507f1f77bcf86cd799439012",
//     "username": "john_doe",
//     "email": "john@example.com",
//     "fullName": "John Doe Updated",
//     "status": true,  <-- Status is now TRUE
//     "loginCount": 5,
//     "isDeleted": false,
//     "createdAt": "2024-03-02T10:00:00.000Z",
//     "updatedAt": "2024-03-02T10:03:00.000Z"
//   }
// }

// ==================== DISABLE USER (Set status = false) ====================

POST http://localhost:5000/api/users/disable
Content-Type: application/json

{
  "email": "jane@example.com",
  "username": "jane_smith"
}

// Response:
// {
//   "message": "User disabled successfully",
//   "data": {
//     "_id": "507f1f77bcf86cd799439013",
//     "username": "jane_smith",
//     "email": "jane@example.com",
//     "fullName": "Jane Smith",
//     "status": false,  <-- Status is now FALSE
//     "loginCount": 0,
//     "isDeleted": false,
//     "createdAt": "2024-03-02T10:00:00.000Z",
//     "updatedAt": "2024-03-02T10:04:00.000Z"
//   }
// }

// ==================== DELETE USER (SOFT DELETE) ====================

DELETE http://localhost:5000/api/users/507f1f77bcf86cd799439012

